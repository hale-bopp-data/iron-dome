#!/usr/bin/env bash
# ============================================================================
# Iron Dome — Pre-Commit Hook
# ============================================================================
# Guards: secrets, conflict markers, docker run, large file, sensitive file,
#         encoding, path length, debt (advisory).
#
# Install: iron-dome init
# The Dumb Guard: no AI, no LLM — pure enforcement.
# ============================================================================

set -euo pipefail

# Find Iron Dome installation
IRON_DOME_HOME="${IRON_DOME_HOME:-}"
if [[ -z "$IRON_DOME_HOME" ]]; then
  # Check common locations
  for candidate in \
    "$HOME/.iron-dome" \
    "/opt/iron-dome" \
    "/usr/local/share/iron-dome" \
    "$(dirname "$(dirname "${BASH_SOURCE[0]}")")"; do
    if [[ -f "$candidate/src/iron-dome-core.sh" ]]; then
      IRON_DOME_HOME="$candidate"
      break
    fi
  done
fi

if [[ -z "$IRON_DOME_HOME" ]] || [[ ! -f "$IRON_DOME_HOME/src/iron-dome-core.sh" ]]; then
  echo "Iron Dome: core not found. Run 'iron-dome doctor' to diagnose."
  echo "Set IRON_DOME_HOME or reinstall: https://github.com/hale-bopp-data/iron-dome"
  exit 0  # Fail open — don't block if Iron Dome is not installed
fi

source "$IRON_DOME_HOME/src/iron-dome-core.sh"
_load_guards

# --- Get staged files ---
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

ERRORS=0

echo "Iron Dome v${IRON_DOME_VERSION}: Pre-Commit Scan..."

# --- Run guards on each file (respects iron-dome.yml config) ---
for file in $STAGED_FILES; do
  [[ ! -f "$file" ]] && continue

  # Sensitive file guard (checks filename, not content)
  if _is_guard_enabled "sensitive_files" && type guard_sensitive_files &>/dev/null; then
    guard_sensitive_files "$file" || ERRORS=$((ERRORS + 1))
  fi

  # Large file guard
  if _is_guard_enabled "large_file" && type guard_large_file &>/dev/null; then
    guard_large_file "$file" || ERRORS=$((ERRORS + 1))
  fi

  # Skip binary/large for content scanning
  if _should_skip_file "$file"; then
    continue
  fi

  # Secrets scan
  _is_guard_enabled "secrets" && guard_secrets "$file" || true

  # Conflict markers
  _is_guard_enabled "conflict_markers" && guard_conflict_markers "$file" || true

  # Docker run guard
  _is_guard_enabled "docker_run" && type guard_docker_run &>/dev/null && guard_docker_run "$file" || true

  # Debt guard (advisory — never blocks)
  _is_guard_enabled "debt" && type guard_debt &>/dev/null && guard_debt "$file" || true
done

# --- Evaluate results ---
local_blocking=$((IRON_DOME_SECRETS_FOUND + IRON_DOME_CONFLICTS_FOUND + IRON_DOME_DOCKER_FOUND + IRON_DOME_OTHER_FOUND + ERRORS))

if [[ $local_blocking -gt 0 ]]; then
  echo ""
  echo "BLOCKED: ${local_blocking} violation(s) found. Commit rejected."
  echo "Fix the issues above and try again."
  echo ""
  _guard_log "pre-commit" "blocking" "${local_blocking} violations in staged files"
  exit 1
fi

if [[ $IRON_DOME_ADVISORY_FOUND -gt 0 ]]; then
  echo "  ${IRON_DOME_ADVISORY_FOUND} advisory note(s) (non-blocking)."
fi

echo "Iron Dome: all checks passed."
exit 0
