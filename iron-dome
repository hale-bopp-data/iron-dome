#!/usr/bin/env bash
# ============================================================================
# Iron Dome — CLI
# ============================================================================
# The Dumb Guard: non-AI security for AI-assisted development.
#
# Usage:
#   iron-dome init          Install hooks in current repo
#   iron-dome scan          Scan current repo for violations
#   iron-dome doctor        Diagnose installation
#   iron-dome stats         Show telemetry dashboard
#   iron-dome config        Show active configuration
#   iron-dome version       Show version
#
# https://github.com/hale-bopp-data/iron-dome
# ============================================================================

set -euo pipefail

# --- Resolve Iron Dome home ---
IRON_DOME_HOME="${IRON_DOME_HOME:-}"
if [[ -z "$IRON_DOME_HOME" ]]; then
  IRON_DOME_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

if [[ ! -f "$IRON_DOME_HOME/src/iron-dome-core.sh" ]]; then
  echo "Error: iron-dome-core.sh not found in $IRON_DOME_HOME/src/"
  echo "Set IRON_DOME_HOME to the Iron Dome installation directory."
  exit 1
fi

source "$IRON_DOME_HOME/src/iron-dome-core.sh"

# ============================================================================
# COMMANDS
# ============================================================================

cmd_version() {
  echo "Iron Dome v${IRON_DOME_VERSION}"
  echo "The Dumb Guard: non-AI security for AI-assisted development."
  echo "https://github.com/hale-bopp-data/iron-dome"
}

cmd_init() {
  echo "Iron Dome v${IRON_DOME_VERSION} — Installing hooks..."
  echo ""

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  if [[ -z "$repo_root" ]]; then
    echo "Error: not inside a git repository."
    exit 1
  fi

  local hooks_dir="${repo_root}/.git/hooks"

  # Install pre-commit hook
  local pre_commit_src="${IRON_DOME_HOME}/src/hooks/pre-commit"
  if [[ -f "$pre_commit_src" ]]; then
    if [[ -f "${hooks_dir}/pre-commit" ]]; then
      # Backup existing hook
      cp "${hooks_dir}/pre-commit" "${hooks_dir}/pre-commit.backup.$(date +%s)"
      echo "  Backed up existing pre-commit hook"
    fi
    cp "$pre_commit_src" "${hooks_dir}/pre-commit"
    chmod +x "${hooks_dir}/pre-commit"
    echo "  Installed: pre-commit (secrets, conflicts, docker, large file, sensitive file)"
  fi

  # Install pre-push hook
  local pre_push_src="${IRON_DOME_HOME}/src/hooks/pre-push"
  if [[ -f "$pre_push_src" ]]; then
    if [[ -f "${hooks_dir}/pre-push" ]]; then
      cp "${hooks_dir}/pre-push" "${hooks_dir}/pre-push.backup.$(date +%s)"
      echo "  Backed up existing pre-push hook"
    fi
    cp "$pre_push_src" "${hooks_dir}/pre-push"
    chmod +x "${hooks_dir}/pre-push"
    echo "  Installed: pre-push (branch policy, semaphore, orphan guard)"
  fi

  # Copy default iron-dome.yml if not present
  if [[ ! -f "${repo_root}/iron-dome.yml" ]]; then
    if [[ -f "${IRON_DOME_HOME}/iron-dome.yml" ]]; then
      cp "${IRON_DOME_HOME}/iron-dome.yml" "${repo_root}/iron-dome.yml"
      echo "  Created:   iron-dome.yml (default config — customize as needed)"
    fi
  else
    echo "  Exists:    iron-dome.yml (not overwritten)"
  fi

  # Set IRON_DOME_HOME in hooks via environment
  # Write a small shim that sets the env var
  cat > "${hooks_dir}/iron-dome-env.sh" << EOF
# Auto-generated by iron-dome init — do not edit
export IRON_DOME_HOME="${IRON_DOME_HOME}"
EOF
  echo "  Created:   .git/hooks/iron-dome-env.sh"

  # Patch hooks to source the env file
  for hook in pre-commit pre-push; do
    local hook_file="${hooks_dir}/${hook}"
    if [[ -f "$hook_file" ]]; then
      # Insert env source after shebang if not already present
      if ! grep -q 'iron-dome-env.sh' "$hook_file" 2>/dev/null; then
        sed -i '2i\\n# Iron Dome environment\nHOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"\n[[ -f "$HOOK_DIR/iron-dome-env.sh" ]] && source "$HOOK_DIR/iron-dome-env.sh"' "$hook_file" 2>/dev/null || true
      fi
    fi
  done

  # Create telemetry directory
  mkdir -p "${HOME}/.iron-dome" 2>/dev/null || true

  echo ""
  echo "Iron Dome installed in: ${repo_root}"
  echo ""
  echo "Next steps:"
  echo "  1. Review iron-dome.yml and enable/disable guards as needed"
  echo "  2. Run 'iron-dome doctor' to verify installation"
  echo "  3. Run 'iron-dome scan --all' to check existing files"
}

cmd_doctor() {
  echo "Iron Dome v${IRON_DOME_VERSION} — Diagnostics"
  echo ""

  local issues=0

  # Check: git repo
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  if [[ -z "$repo_root" ]]; then
    echo "  [FAIL] Not inside a git repository"
    issues=$((issues + 1))
  else
    echo "  [ OK ] Git repository: $(basename "$repo_root")"
  fi

  # Check: IRON_DOME_HOME
  echo "  [INFO] IRON_DOME_HOME: $IRON_DOME_HOME"

  # Check: core.sh
  if [[ -f "$IRON_DOME_HOME/src/iron-dome-core.sh" ]]; then
    echo "  [ OK ] Core engine found"
  else
    echo "  [FAIL] Core engine NOT found"
    issues=$((issues + 1))
  fi

  # Check: guards
  local guard_dir="$IRON_DOME_HOME/src/guards"
  if [[ -d "$guard_dir" ]]; then
    local guard_count
    guard_count=$(ls -1 "$guard_dir"/*.sh 2>/dev/null | wc -l)
    echo "  [ OK ] Guards: ${guard_count} loaded from $guard_dir"
  else
    echo "  [WARN] Guards directory not found"
  fi

  # Check: hooks installed
  if [[ -n "$repo_root" ]]; then
    local hooks_dir="${repo_root}/.git/hooks"
    if [[ -f "${hooks_dir}/pre-commit" ]] && grep -q "iron-dome\|Iron Dome" "${hooks_dir}/pre-commit" 2>/dev/null; then
      echo "  [ OK ] pre-commit hook: installed"
    else
      echo "  [WARN] pre-commit hook: not installed (run 'iron-dome init')"
    fi
    if [[ -f "${hooks_dir}/pre-push" ]] && grep -q "iron-dome\|Iron Dome" "${hooks_dir}/pre-push" 2>/dev/null; then
      echo "  [ OK ] pre-push hook: installed"
    else
      echo "  [WARN] pre-push hook: not installed (run 'iron-dome init')"
    fi
  fi

  # Check: iron-dome.yml
  if [[ -n "$repo_root" ]] && [[ -f "${repo_root}/iron-dome.yml" ]]; then
    echo "  [ OK ] iron-dome.yml: found in repo root"
  else
    echo "  [INFO] iron-dome.yml: not found (using defaults)"
  fi

  # Check: .iron-dome.yml (per-repo override)
  if [[ -n "$repo_root" ]] && [[ -f "${repo_root}/.iron-dome.yml" ]]; then
    echo "  [ OK ] .iron-dome.yml: per-repo override found"
  fi

  # Check: dependencies
  if command -v grep &>/dev/null && grep --version 2>&1 | grep -q "GNU\|PCRE\|ripgrep" 2>/dev/null; then
    echo "  [ OK ] grep: supports -P (PCRE)"
  else
    echo "  [WARN] grep: may not support -P flag (some patterns won't work)"
  fi

  if command -v python3 &>/dev/null; then
    echo "  [ OK ] python3: $(python3 --version 2>&1)"
  else
    echo "  [WARN] python3: not found (stats, semaphore, orphan guard require it)"
  fi

  # Check: telemetry
  local telemetry_file="${HOME}/.iron-dome/telemetry.jsonl"
  if [[ -f "$telemetry_file" ]]; then
    local entry_count
    entry_count=$(wc -l < "$telemetry_file" 2>/dev/null || echo 0)
    echo "  [ OK ] Telemetry: ${entry_count} entries in $telemetry_file"
  else
    echo "  [INFO] Telemetry: no data yet"
  fi

  echo ""
  if [[ $issues -eq 0 ]]; then
    echo "Iron Dome is healthy."
  else
    echo "Found $issues issue(s). Fix them and run 'iron-dome doctor' again."
  fi
}

cmd_stats() {
  local days="${1:-30}"
  local telemetry_file="${HOME}/.iron-dome/telemetry.jsonl"

  if [[ ! -f "$telemetry_file" ]]; then
    echo "No telemetry data yet. Iron Dome logs interventions automatically."
    echo "File: $telemetry_file"
    return 0
  fi

  python3 -c "
import json, sys
from datetime import datetime, timedelta
from collections import Counter

days = $days
telemetry_file = '$telemetry_file'

total = 0
by_guard = Counter()
by_severity = Counter()
by_repo = Counter()
blocked = 0

with open(telemetry_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            total += 1
            by_guard[entry.get('guard', '?')] += 1
            sev = entry.get('severity', '?')
            by_severity[sev] += 1
            if sev == 'blocking':
                blocked += 1
            by_repo[entry.get('repo', '?')] += 1
        except:
            continue

print(f'=== Iron Dome Stats — last {days} days ===')
print(f'Total interventions: {total}')
print(f'Commits/pushes blocked: {blocked}')
print()
print('By guard:')
for g, c in by_guard.most_common():
    print(f'  {g}: {c}')
print()
print('By severity:')
for s, c in by_severity.most_common():
    print(f'  {s}: {c}')
print()
print('By repo:')
for r, c in by_repo.most_common(10):
    print(f'  {r}: {c}')
print()
if blocked > 0:
    print(f'Iron Dome has blocked {blocked} dangerous operation(s).')
else:
    print('No blocks recorded. Your team is clean (or Iron Dome was just installed).')
" 2>/dev/null || echo "Stats require python3. Install it and try again."
}

cmd_scan() {
  shift 2>/dev/null || true  # Remove 'scan' from args
  bash "$IRON_DOME_HOME/src/iron-dome-scan.sh" "$@"
}

cmd_config() {
  echo "Iron Dome v${IRON_DOME_VERSION} — Active Configuration"
  echo ""
  echo "IRON_DOME_HOME:    $IRON_DOME_HOME"

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")

  if [[ -f "${repo_root}/iron-dome.yml" ]]; then
    echo "Config file:       ${repo_root}/iron-dome.yml"
    echo ""
    cat "${repo_root}/iron-dome.yml"
  elif [[ -f "${IRON_DOME_HOME}/iron-dome.yml" ]]; then
    echo "Config file:       ${IRON_DOME_HOME}/iron-dome.yml (default)"
    echo ""
    cat "${IRON_DOME_HOME}/iron-dome.yml"
  else
    echo "Config file:       (none — using built-in defaults)"
  fi

  if [[ -f "${repo_root}/.iron-dome.yml" ]]; then
    echo ""
    echo "--- Per-repo override: ${repo_root}/.iron-dome.yml ---"
    cat "${repo_root}/.iron-dome.yml"
  fi
}

cmd_help() {
  echo "Iron Dome v${IRON_DOME_VERSION}"
  echo "The Dumb Guard: non-AI security for AI-assisted development."
  echo ""
  echo "Usage: iron-dome <command> [options]"
  echo ""
  echo "Commands:"
  echo "  init              Install hooks in current git repo"
  echo "  scan [options]    Scan files for violations"
  echo "    --changed-only  Scan only changed files (default)"
  echo "    --all           Scan all files"
  echo "    --verbose       Show each file being scanned"
  echo "  doctor            Diagnose installation"
  echo "  stats [days]      Show telemetry dashboard (default: 30 days)"
  echo "  config            Show active configuration"
  echo "  version           Show version"
  echo "  help              Show this help"
  echo ""
  echo "Environment variables:"
  echo "  IRON_DOME_HOME              Installation directory"
  echo "  IRON_DOME_SESSION           Current session ID (for semaphore)"
  echo "  IRON_DOME_AGENT             Current agent name (for semaphore)"
  echo "  IRON_DOME_BRANCH_SKIP=1     Bypass branch policy guard"
  echo "  IRON_DOME_SEMAPHORE_SKIP=1  Bypass semaphore check"
  echo "  IRON_DOME_ORPHAN_SKIP=1     Bypass orphan guard"
  echo ""
  echo "https://github.com/hale-bopp-data/iron-dome"
}

# ============================================================================
# DISPATCH
# ============================================================================

case "${1:-help}" in
  init)     cmd_init ;;
  scan)     cmd_scan "$@" ;;
  doctor)   cmd_doctor ;;
  stats)    cmd_stats "${2:-30}" ;;
  config)   cmd_config ;;
  version)  cmd_version ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'iron-dome help' for usage."
    exit 1
    ;;
esac
